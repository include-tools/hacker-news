{
  "name": "items.recent skips null/deleted/failed ids within the scan budget",
  "tool": "items.recent",
  "args": { "limit": 3 },
  "fixtures": [
    { "pattern": "hacker-news.firebaseio.com/v0/maxitem.json", "json": 100 },
    { "pattern": "hacker-news.firebaseio.com/v0/item/100.json", "json": "null" },
    {
      "pattern": "hacker-news.firebaseio.com/v0/item/99.json",
      "json": { "id": 99, "type": "comment", "deleted": true }
    },
    { "pattern": "hacker-news.firebaseio.com/v0/item/98.json", "status": 500 },
    {
      "pattern": "hacker-news.firebaseio.com/v0/item/97.json",
      "json": { "id": 97, "type": "comment", "by": "a", "text": "live97" }
    },
    {
      "pattern": "hacker-news.firebaseio.com/v0/item/96.json",
      "json": { "id": 96, "type": "comment", "by": "b", "text": "live96" }
    },
    {
      "pattern": "hacker-news.firebaseio.com/v0/item/95.json",
      "json": { "id": 95, "type": "comment", "by": "c", "text": "live95" }
    }
  ],
  "expect": {
    "contains": [
      "\"items_returned\":3",
      "\"ids_scanned\":6",
      "\"skipped_null\":1",
      "\"skipped_deleted_or_dead\":1",
      "\"failed_fetch\":1",
      "live97",
      "live95"
    ],
    "calls": [
      { "method": "GET", "host": "hacker-news.firebaseio.com", "path": "/v0/maxitem.json" },
      { "method": "GET", "host": "hacker-news.firebaseio.com", "path": "/v0/item/100.json" },
      { "method": "GET", "host": "hacker-news.firebaseio.com", "path": "/v0/item/99.json" },
      { "method": "GET", "host": "hacker-news.firebaseio.com", "path": "/v0/item/98.json" },
      { "method": "GET", "host": "hacker-news.firebaseio.com", "path": "/v0/item/97.json" },
      { "method": "GET", "host": "hacker-news.firebaseio.com", "path": "/v0/item/96.json" },
      { "method": "GET", "host": "hacker-news.firebaseio.com", "path": "/v0/item/95.json" }
    ]
  }
}
