{
  "name": "updates.get surfaces upstream_error on a non-2xx response",
  "tool": "updates.get",
  "args": {},
  "fixtures": [
    { "pattern": "hacker-news.firebaseio.com/v0/updates.json", "status": 500 }
  ],
  "expect": {
    "errorContains": "upstream_error",
    "calls": [
      { "method": "GET", "host": "hacker-news.firebaseio.com", "path": "/v0/updates.json" }
    ]
  }
}
