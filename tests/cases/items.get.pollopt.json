{
  "name": "items.get returns a poll option with its parent poll and score",
  "tool": "items.get",
  "args": { "id": 160705 },
  "fixtures": [
    {
      "pattern": "hacker-news.firebaseio.com/v0/item/160705.json",
      "json": {
        "id": 160705,
        "type": "pollopt",
        "by": "pg",
        "time": 1207886576,
        "poll": 160704,
        "score": 335,
        "text": "Yes, ban them; I'm tired of seeing Valleywag stories on News.YC."
      }
    }
  ],
  "expect": {
    "contains": ["\"type\":\"pollopt\"", "\"poll\":160704", "\"score\":335"],
    "calls": [
      { "method": "GET", "host": "hacker-news.firebaseio.com", "path": "/v0/item/160705.json" }
    ]
  }
}
