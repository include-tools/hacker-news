{
  "name": "users.get tallies skipped/failed submissions and keeps the count invariant",
  "tool": "users.get",
  "args": { "username": "bob", "include_recent": 3 },
  "fixtures": [
    {
      "pattern": "hacker-news.firebaseio.com/v0/user/bob.json",
      "json": { "id": "bob", "created": 1300000000, "karma": 2, "submitted": [20, 21, 22] }
    },
    { "pattern": "hacker-news.firebaseio.com/v0/item/20.json", "json": "null" },
    {
      "pattern": "hacker-news.firebaseio.com/v0/item/21.json",
      "json": { "id": 21, "type": "story", "dead": true }
    },
    { "pattern": "hacker-news.firebaseio.com/v0/item/22.json", "status": 500 }
  ],
  "expect": {
    "contains": [
      "\"submissions_requested\":3",
      "\"submissions_returned\":0",
      "\"skipped_null\":1",
      "\"skipped_deleted_or_dead\":1",
      "\"failed_fetch\":1"
    ],
    "calls": [
      { "method": "GET", "host": "hacker-news.firebaseio.com", "path": "/v0/user/bob.json" },
      { "method": "GET", "host": "hacker-news.firebaseio.com", "path": "/v0/item/20.json" },
      { "method": "GET", "host": "hacker-news.firebaseio.com", "path": "/v0/item/21.json" },
      { "method": "GET", "host": "hacker-news.firebaseio.com", "path": "/v0/item/22.json" }
    ]
  }
}
